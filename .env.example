# Anthropic (required for Claude Code / Ralph)
ANTHROPIC_API_KEY=sk-ant-...

# Postgres (for MCP price storage)
DATABASE_URL=postgres://user:pass@localhost:5432/arb_prices

# Telegram (for alert notifications)
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_CHAT_ID=your_chat_id

# Market APIs
POLYMARKET_API_KEY=
KALSHI_API_KEY=
PREDICTIT_API_KEY=

# Risk parameters (optional overrides)
MAX_SINGLE_POSITION_PCT=2.0
MAX_TOTAL_EXPOSURE_PCT=20.0
MIN_SPREAD_PCT=0.5
